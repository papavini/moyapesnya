# ─── Telegram ─────────────────────────────────────────────────────────────────
# BotFather -> /newbot -> получишь токен вида 123456789:ABC-DEF...
TELEGRAM_BOT_TOKEN=

# ─── VK (необязательно) ───────────────────────────────────────────────────────
# Сообщество -> Управление -> Работа с API -> Ключи доступа
# Включить: Long Poll API (последняя версия), событие "messages_new"
VK_GROUP_TOKEN=
VK_GROUP_ID=

# ─── SUNO API (self-hosted gcui-art/suno-api) ─────────────────────────────────
# URL сервиса suno-api (на той же машине — localhost:3000)
SUNO_API_BASE=http://localhost:3000

# Сколько секунд ждём готовности трека (2-5 минут реально, ставь с запасом)
SUNO_POLL_TIMEOUT_SEC=480

# Как часто опрашиваем статус генерации
SUNO_POLL_INTERVAL_SEC=5

# true = отправить только первый из двух клипов (SUNO всегда генерирует 2)
SUNO_SEND_FIRST_ONLY=false

# ─── Монетизация ──────────────────────────────────────────────────────────────
# false = MVP-режим, всё бесплатно. true = включить пейволл (не реализован)
PAYWALL_ENABLED=false
